<ui:FluentWindow x:Class="TarkovAF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Tarkov Monitor" Height="500" Width="700" 
        Background="{ui:ThemeResource ApplicationBackgroundBrush}">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <ui:TextBlock Text="TARKOV MONITOR" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

            <ui:Card Margin="0,0,0,10">
                <StackPanel Margin="10">
                    <ui:TextBlock x:Name="txtStatus" Text="STATUS: IDLE" Foreground="Gray"/>
                    <ui:TextBlock x:Name="txtUptime" Text="Session: 00:00:00"/>
                    <ui:TextBlock x:Name="txtNextAFK" Text="Next AFK: --" Foreground="Cyan"/>
                </StackPanel>
            </ui:Card>

            <ui:Button Content="Select Launcher" Click="btnLauncher_Click" Margin="0,5"/>
            <ui:TextBlock x:Name="txtLauncherPath" Text="No path set" Foreground="Gray" Margin="5,0"/>

            <ui:TextBox x:Name="txtLog" Height="100" Margin="0,10,0,0" IsReadOnly="True" FontFamily="Consolas"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="20,40,0,0">
            <ui:Button x:Name="btnStart" Content="START" Height="50" Width="150" Appearance="Primary" Click="btnStart_Click" Margin="0,5"/>
            <ui:Button x:Name="btnStop" Content="STOP" Height="40" Width="150" Appearance="Danger" Click="btnStop_Click" Margin="0,5" IsEnabled="False"/>
            <ui:Button x:Name="btnCapture" Content="Set Play (Hold P)" Height="40" Width="150" Click="btnCapture_Click" Margin="0,5"/>
            <ui:Button Content="AFK Test" Height="40" Width="150" Click="btnAFKTest_Click" Margin="0,5"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>